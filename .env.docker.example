# ARIA self-hosted (Docker Compose) configuration.
# Copy this file to `.env` in the repo root, then fill in the two secrets below.
#   cp .env.docker.example .env

# ── Required secrets ─────────────────────────────────────────────────────
# A secret that protects the bootstrap endpoint (/v1/setup). Any long random
# string. Generate one with:  openssl rand -hex 24
SETUP_KEY=

# AES-256-GCM key for encrypting agent secrets at rest. MUST be exactly
# 64 hex characters (32 bytes). Generate one with:  openssl rand -hex 32
ENCRYPTION_KEY=

# ── Optional ─────────────────────────────────────────────────────────────
# Public port the ARIA edge (membrane) listens on. Default 8080.
ARIA_PORT=8080

# Password for the bundled Postgres. Change it for anything beyond local dev.
POSTGRES_PASSWORD=aria_local_dev

# CORS allowlist and base URL used in links/emails. For purely local use the
# defaults are fine; set these to your domain if you expose ARIA on a host.
ALLOWED_ORIGINS=http://localhost:8080
APP_URL=http://localhost:8080
