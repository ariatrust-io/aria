# Required
SETUP_KEY=your-secure-random-key-here
DATABASE_URL=postgresql://user:password@localhost:5432/agentrust
ENCRYPTION_KEY=your-32-byte-hex-key-here

# Ports
# PORT is the public membrane port. INTERNAL_PORT is the internal API
# (bound to localhost, never exposed). They must be different.
PORT=8080
INTERNAL_PORT=3000

NODE_ENV=development
ALLOWED_ORIGINS=https://ariatrust.org
APP_URL=https://ariatrust.org
REDIS_URL=redis://localhost:6379
# DB_POOL_MAX=8

# OAuth (optional). Buttons stay visible but endpoints return 503 if unset.
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Email (optional, Resend)
# RESEND_API_KEY=your-resend-key

# Billing (optional, Lemon Squeezy)
# LEMONSQUEEZY_API_KEY=your-ls-key
# LEMONSQUEEZY_STORE_ID=your-store-id
# LEMONSQUEEZY_PROFESSIONAL_VARIANT_ID=your-pro-variant-id
# LEMONSQUEEZY_BUSINESS_VARIANT_ID=your-business-variant-id
# LEMONSQUEEZY_WEBHOOK_SECRET=your-ls-webhook-secret